{
  "name": "editor",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build:workspace-deps": "bun run --cwd ../../packages/core build && bun run --cwd ../../packages/viewer build",
    "sync-assets": "node ../../packages/editor-assets/bin/pascal-editor-assets.mjs sync --target ./public --clean",
    "dev": "bun run build:workspace-deps && bun run sync-assets && dotenv -e ./.env.local --override -- next dev --port 3002",
    "build": "bun run build:workspace-deps && bun run sync-assets && dotenv -e ./.env.local --override -- next build",
    "start": "bun run sync-assets && next start",
    "lint": "biome lint",
    "check-types": "bun run build:workspace-deps && bun run sync-assets && next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@number-flow/react": "^0.5.14",
    "@pascal-app/core": "*",
    "@pascal-app/editor": "*",
    "@pascal-app/editor-assets": "workspace:*",
    "@pascal-app/viewer": "*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/postcss": "^4.2.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "next": "16.2.1",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.1"
  },
  "devDependencies": {
    "@pascal/typescript-config": "*",
    "@types/howler": "^2.2.12",
    "@types/node": "^22.19.12",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "react-grab": "^0.1.25",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}
